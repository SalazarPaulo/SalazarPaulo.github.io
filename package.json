{
  "name": "dev-arcade-portfolio",
  "private": true,
  "version": "1.0.0",
  "description": "Static arcade portfolio prepared for GitHub Pages.",
  "scripts": {
    "format": "prettier --write index.html styles.css script.js",
    "check": "node --check script.js",
    "check:bundle": "node --check script.min.js",
    "build:css": "lightningcss styles.css --minify --output-file styles.min.css",
    "build:js": "esbuild script.js --minify --outfile=script.min.js",
    "build": "pnpm run check && pnpm run build:css && pnpm run build:js && pnpm run check:bundle"
  },
  "devDependencies": {
    "esbuild": "0.25.0",
    "lightningcss-cli": "1.30.1",
    "prettier": "3.8.4"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.9.0"
  }
}
